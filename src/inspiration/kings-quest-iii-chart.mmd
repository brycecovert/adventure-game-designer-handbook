        A_SQUEEZE_JUICE --> O_RECEIVE_CACTUS_JUICE["O: Receive Cactus Juice"]
        
        A_GO_TO_WATERFALL --> A_WAIT_EAGLE["A: Wait for eagle to fly by"]

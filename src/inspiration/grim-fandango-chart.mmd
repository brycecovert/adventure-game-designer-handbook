        A_FIND_TOY_STORE --> O_BUY_REPLACEMENT["O: Buy Replacement Doll Head"]

        O_BUY_REPLACEMENT --> A_GIVE_DOLL_TO_MECHES["A: Give Repaired Doll to Meche at DOD"]
        A_GIVE_DOLL_TO_MECHES --> O_MEHE_TRUSTS["O: Meche Now Trusts Manny"]
    end

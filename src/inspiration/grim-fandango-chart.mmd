    subgraph area_8["**YEAR 3 - FORKLIFT ELEVATOR HEIST**"]
        O_HIDDEN_OKAY --> C9["C9: Wait for Cask Transport via Forklift"]

        C9 --> A_RIDE_FORKLIFT_DOWN["A: Board Forklift Vehicle Loading Empty Casks to Basement Level"]
